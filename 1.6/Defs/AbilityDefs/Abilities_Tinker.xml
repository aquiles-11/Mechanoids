<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <AbilityDef>
    <defName>APM_BlindingLaser</defName>
    <label>blinding laser</label>
    <description>todo</description>
    <iconPath>UI/Icons/Laser</iconPath>
    <showPsycastEffects>false</showPsycastEffects>
    <cooldownTicksRange>850</cooldownTicksRange>
    <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
    <uiOrder>2</uiOrder>
    <showWhenDrafted>true</showWhenDrafted>
    <hostile>false</hostile>
    <statBases>
      <Ability_Duration>500</Ability_Duration>
      <Ability_EffectRadius>3.9</Ability_EffectRadius>
    </statBases>
    <comps>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>APM_LaserBlind</hediffDef>
        <onlyBrain>false</onlyBrain>
      </li>
      <li Class="ApexMechanoids.CompProperties_AbilityMoteDualAttachedOnTarget">
        <preCastTicks>1</preCastTicks>
        <moteDef>APM_Mote_BlindingLaser</moteDef>
      </li>
    </comps>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <drawAimPie>true</drawAimPie>
      <range>11</range>
      <warmupTime>0.6</warmupTime>
      <targetParams>
        <canTargetSelf>false</canTargetSelf>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetMechs>true</canTargetMechs>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
    </verbProperties>
  </AbilityDef>

  <ThingDef ParentName="MoteBase">
    <defName>APM_Mote_BlindingLaser</defName>
    <thingClass>MoteDualAttached</thingClass>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <mote>
      <fadeInTime>0.1</fadeInTime>
      <fadeOutTime>0.1</fadeOutTime>
      <solidTime>0.1</solidTime>
      <rotateTowardsTarget>True</rotateTowardsTarget>
      <scaleToConnectTargets>True</scaleToConnectTargets>
    </mote>
    <drawOffscreen>true</drawOffscreen>
    <graphicData>
      <texPath>Things/Mote/GraserBeam</texPath>
      <graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
      <shaderType>MoteBeam</shaderType>
      <color>(0.82, 0.6, 0.44)</color>
      <drawSize>(2, 1)</drawSize>
      <shaderParameters>
        <_ExtraTexA>/Things/Mote/BeamSecondaryNoise_A</_ExtraTexA>
        <_ExtraTexB>/Things/Mote/BeamSecondaryNoise_B</_ExtraTexB>
        <_ScrollSpeedA>0</_ScrollSpeedA>
        <_ScrollSpeedB>0</_ScrollSpeedB>
        <_Intensity>2</_Intensity>
      </shaderParameters>
    </graphicData>
  </ThingDef>

  <HediffDef>
    <defName>APM_LaserBlind</defName>
    <label>blinded by laser</label>
    <description>todo</description>
    <isBad>false</isBad>
    <defaultLabelColor>(0.82, 0.6, 0.44)</defaultLabelColor>
    <initialSeverity>1</initialSeverity>
    <maxSeverity>1</maxSeverity>
    <hediffClass>HediffWithComps</hediffClass>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Sight</capacity>
            <setMax>0.25</setMax>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_DisappearsOnDeath"/>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>True</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <AbilityDef>
    <defName>APM_DefenceMatrix</defName>
    <label>defence matrix</label>
    <description>Remotely project a personal defense shield onto a mech. The shield stops incoming damage, but also prevents shooting out, so this can be useful even when cast on enemies. The tinker must continuously focus on the mech in order to maintain the shield.</description>
    <jobDef>ShieldMech</jobDef>
    <targetRequired>true</targetRequired>
    <canUseAoeToGetTargets>False</canUseAoeToGetTargets>
    <iconPath>UI/Icons/Matrix</iconPath>
    <stunTargetWhileCasting>True</stunTargetWhileCasting>
    <showPsycastEffects>False</showPsycastEffects>
    <hotKey>Misc12</hotKey>
    <uiOrder>3</uiOrder>
    <displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
    <cooldownTicksRange>300</cooldownTicksRange>
    <waitForJobEnd>true</waitForJobEnd>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>7.9</range>
      <rangeStat>MechRemoteShieldDistance</rangeStat>
      <drawAimPie>true</drawAimPie>
      <requireLineOfSight>true</requireLineOfSight>
      <warmupTime>0</warmupTime>
      <targetParams>
        <canTargetSelf>false</canTargetSelf>
        <canTargetPawns>true</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetAnimals>false</canTargetAnimals>
        <canTargetHumans>false</canTargetHumans>
        <canTargetMechs>true</canTargetMechs>
      </targetParams>
    </verbProperties>
  </AbilityDef>

</Defs>