<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="BaseGun">
        <defName>APM_Gun_EMP_Impactor</defName>
        <label>EMP impactor</label>
        <description>A mechanoid grade electromagnetic grenade launcher, featuring better accuracy, a larger range and a bigger blast than more common variants of the same type. Organic life has many clear weaknesses, yet militaries still use said threats in their arsenals all the same. The mechhive is no different.</description>
        <techLevel>Spacer</techLevel>
        <graphicData>
            <texPath>Things/Item/Equipment/WeaponRanged/DynamoEMPImpactor</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>1.2</drawSize>
        </graphicData>
        <soundInteract>Interact_GrenadeLauncher</soundInteract>
        <destroyOnDrop>true</destroyOnDrop>
        <tradeability>None</tradeability>
        <statBases>
            <MarketValue>1800</MarketValue>
            <Mass>6.0</Mass>
            <AccuracyTouch>0.60</AccuracyTouch>
            <AccuracyShort>0.78</AccuracyShort>
            <AccuracyMedium>0.72</AccuracyMedium>
            <AccuracyLong>0.55</AccuracyLong>
            <RangedWeapon_Cooldown>2.8</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>APM_WeaponEMPImpactor</li>
        </weaponTags>
        <weaponClasses>
            <li>RangedHeavy</li>
        </weaponClasses>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>APM_Proj_EMP_Impactor</defaultProjectile>
                <warmupTime>1.2</warmupTime>
                <range>28.9</range>
                <burstShotCount>1</burstShotCount>
                <forcedMissRadius>1.5</forcedMissRadius>
                <soundCast>Shot_GrenadeLauncher</soundCast>
                <soundCastTail>GunTail_Medium</soundCastTail>
                <muzzleFlashScale>10</muzzleFlashScale>
                <targetParams>
                    <canTargetLocations>true</canTargetLocations>
                </targetParams>
                <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
            </li>
        </verbs>
        <tools>
            <li>
                <label>stock</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
                <label>barrel</label>
                <capacities>
                    <li>Blunt</li>
                    <li>Poke</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
        </tools>
    </ThingDef>

    <ThingDef ParentName="BaseFragGrenadeProjectile">
        <defName>APM_Proj_EMP_Impactor</defName>
        <label>EMP impactor projectile</label>
        <thingClass>Projectile_Explosive</thingClass>
        <graphicData>
            <texPath>Things/Projectile/GrenadeEMP</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile>
            <damageDef>EMP</damageDef>
            <damageAmountBase>30</damageAmountBase>
            <explosionRadius>4.9</explosionRadius>
            <explosionDelay>2</explosionDelay>
            <speed>18</speed>
        </projectile>
    </ThingDef>
</Defs>
