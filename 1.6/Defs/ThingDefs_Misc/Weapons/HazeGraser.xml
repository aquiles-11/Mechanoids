<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ===== Beam Mote ===== -->
	<ThingDef ParentName="MoteBase">
		<defName>APM_Mote_HazeBeam_Base</defName>
		<thingClass>MoteDualAttached</thingClass>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<mote>
			<fadeInTime>0.2</fadeInTime>
			<fadeOutTime>0.3</fadeOutTime>
			<solidTime>999999</solidTime>
			<needsMaintenance>True</needsMaintenance>
			<rotateTowardsTarget>True</rotateTowardsTarget>
			<scaleToConnectTargets>True</scaleToConnectTargets>
			<fadeOutUnmaintained>True</fadeOutUnmaintained>
		</mote>
		<drawOffscreen>true</drawOffscreen>
		<graphicData>
			<texPath>Things/Mote/GraserBeam</texPath>
			<graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
			<shaderType>MoteBeam</shaderType>
			<shaderParameters>
				<_ExtraTexA>/Things/Mote/BeamSecondaryNoise_A</_ExtraTexA>
				<_ExtraTexB>/Things/Mote/BeamSecondaryNoise_B</_ExtraTexB>
				<_ScrollSpeedA>-4</_ScrollSpeedA>
				<_ScrollSpeedB>3</_ScrollSpeedB>
				<_Intensity>2</_Intensity>
			</shaderParameters>
			<color>(60, 220, 80)</color>
			<drawSize>(5.5, 1)</drawSize>
		</graphicData>
	</ThingDef>

	<!-- ===== Damage Def ===== -->
	<DamageDef ParentName="Beam">
		<defName>APM_HazeBeam</defName>
		<label>haze beam</label>
		<defaultDamage>18</defaultDamage>
	</DamageDef>

	<!-- ===== Weapon Def ===== -->
	<ThingDef ParentName="BaseGun">
		<defName>APM_Haze_BeamGun</defName>
		<label>haze graser cannon</label>
		<description>A tesseron's beam grazer twisted into a machine that spews toxic waste in addition to plasma, the products of this cannon are monstrously hazardous to organic life. Fear is only another foothold of the mechanoid superintelligence.</description>
		<graphicData>
			<texPath>Blank</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<uiIconPath>UI/Light</uiIconPath>
		<techLevel>Ultra</techLevel>
		<tradeability>None</tradeability>
		<destroyOnDrop>true</destroyOnDrop>
		<relicChance>0</relicChance>
		<statBases>
			<MarketValue>9999</MarketValue>
			<AccuracyTouch>0.65</AccuracyTouch>
			<AccuracyShort>0.82</AccuracyShort>
			<AccuracyMedium>0.88</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<RangedWeapon_Cooldown>6.0</RangedWeapon_Cooldown>
		</statBases>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<weaponTags Inherit="False">
			<li>APM_WeaponHazeGraser</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>ApexMechanoids.Verb_ShootHazeBeam</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<warmupTime>1.5</warmupTime>
				<range>22.9</range>
				<minRange>3.9</minRange>
				<beamFullWidthRange>6.9</beamFullWidthRange>
				<burstShotCount>8</burstShotCount>
				<showBurstShotStats>false</showBurstShotStats>
				<beamWidth>4</beamWidth>
				<ticksBetweenBurstShots>18</ticksBetweenBurstShots>
				<beamDamageDef>APM_HazeBeam</beamDamageDef>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<soundCastBeam>BeamGraser_Shooting</soundCastBeam>
				<beamGroundFleckDef>Fleck_BeamBurn</beamGroundFleckDef>
				<beamFleckChancePerTick>0.32</beamFleckChancePerTick>
				<beamMaxDeviation>1.5</beamMaxDeviation>
				<beamCurvature>0.6</beamCurvature>
				<beamMoteDef>APM_Mote_HazeBeam_Base</beamMoteDef>
				<beamEndEffecterDef>GraserBeam_End</beamEndEffecterDef>
				<beamChanceToStartFire>0.2</beamChanceToStartFire>
				<beamChanceToAttachFire>0.1</beamChanceToAttachFire>
				<beamFireSizeRange>0.4~0.7</beamFireSizeRange>
				<beamLineFleckDef>Fleck_BeamSpark</beamLineFleckDef>
				<beamStartOffset>0.8</beamStartOffset>
				<beamLineFleckChanceCurve>
					<points>
						<li>(0, 0)</li>
						<li>(0.65, 0.4)</li>
						<li>(1, 0.75)</li>
					</points>
				</beamLineFleckChanceCurve>
			</li>
		</verbs>
	</ThingDef>
</Defs>