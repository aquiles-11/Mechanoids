<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!--
        Severity is set directly by CompUnity (ThingComp on the Conqueror).
        Formula: severity = allyCount * severityPerAlly (default 0.1 per ally)
        So: 1 ally = 0.1 | 3 allies = 0.3 | 5 allies = 0.5 | 7+ allies = 0.7+ (capped at maxSeverity 1.0)
    -->
    <HediffDef>
        <defName>APM_Hediff_Unity</defName>
        <label>unity uplink</label>
        <description>Conquerors are by default installed with processing units that automatically attempt to link with those of allies in the vicinity to assist each other with internal calculations, boosting their efficiency the more nearby.</description>
        <isBad>false</isBad>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.35, 0.85, 1.0)</defaultLabelColor>
        <initialSeverity>0.001</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <stages>
            <!-- 0 allies (severity < 0.1): no effect -->
            <li>
            </li>
            <!-- 1 ally (severity >= 0.1) -->
            <li>
                <minSeverity>0.1</minSeverity>
                <label>weak</label>
                <statOffsets>
                    <MoveSpeed>0.05</MoveSpeed>
                </statOffsets>
                <statFactors>
                    <MeleeDPS>1.03</MeleeDPS>
                    <ShootingAccuracyPawn>1.02</ShootingAccuracyPawn>
                </statFactors>
            </li>
            <!-- 3 allies (severity >= 0.3) -->
            <li>
                <minSeverity>0.3</minSeverity>
                <label>linked</label>
                <statOffsets>
                    <MoveSpeed>0.12</MoveSpeed>
                </statOffsets>
                <statFactors>
                    <MeleeDPS>1.07</MeleeDPS>
                    <ShootingAccuracyPawn>1.05</ShootingAccuracyPawn>
                    <ArmorRating_Sharp>1.04</ArmorRating_Sharp>
                </statFactors>
            </li>
            <!-- 5 allies (severity >= 0.5) -->
            <li>
                <minSeverity>0.5</minSeverity>
                <label>strong</label>
                <statOffsets>
                    <MoveSpeed>0.22</MoveSpeed>
                </statOffsets>
                <statFactors>
                    <MeleeDPS>1.12</MeleeDPS>
                    <ShootingAccuracyPawn>1.09</ShootingAccuracyPawn>
                    <ArmorRating_Sharp>1.08</ArmorRating_Sharp>
                    <ArmorRating_Blunt>1.08</ArmorRating_Blunt>
                </statFactors>
            </li>
            <!-- 7+ allies (severity >= 0.7) -->
            <li>
                <minSeverity>0.7</minSeverity>
                <label>peak</label>
                <statOffsets>
                    <MoveSpeed>0.35</MoveSpeed>
                </statOffsets>
                <statFactors>
                    <MeleeDPS>1.18</MeleeDPS>
                    <ShootingAccuracyPawn>1.14</ShootingAccuracyPawn>
                    <ArmorRating_Sharp>1.12</ArmorRating_Sharp>
                    <ArmorRating_Blunt>1.12</ArmorRating_Blunt>
                    <MeleeCooldownFactor>0.88</MeleeCooldownFactor>
                </statFactors>
            </li>
        </stages>
    </HediffDef>
</Defs>
