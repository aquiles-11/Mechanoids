<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!--
        Applied to pawns devoured and stored inside a Frostivus.
        Purely cosmetic/informational — the actual suspension is handled by
        ContentsInCryptosleep_Patch. This hediff just signals the state visually.
        It does NOT disappear on its own; it is added/removed by code.
    -->
	<HediffDef>
		<defName>APM_Hediff_Devoured</defName>
		<label>devoured</label>
		<description>Sealed inside a Frostivus cryo-chamber. All biological processes are suspended - no bleeding, no sickness progression, no needs.</description>
		<isBad>true</isBad>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.4, 0.8, 1.0)</defaultLabelColor>
		<initialSeverity>1</initialSeverity>
		<maxSeverity>1</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_DisappearsOnDeath"></li>
		</comps>
	</HediffDef>
</Defs>