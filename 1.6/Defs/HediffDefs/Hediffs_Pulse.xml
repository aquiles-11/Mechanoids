<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>APM_PulseWaveBlind</defName>
    <label>flash-blinded</label>
    <description>An intense flash and pressure spike have overwhelmed this pawn's sensors, sharply reducing sight for a short time.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <initialSeverity>1</initialSeverity>
    <maxSeverity>1</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>1920</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Sight</capacity>
            <setMax>0.2</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
