		<playerInterruptible>true</playerInterruptible>
		<checkOverrideOnDamage>Always</checkOverrideOnDamage>
		<alwaysShowWeapon>false</alwaysShowWeapon>
	</JobDef>

	<JobDef>
		<defName>APM_HookPawn</defName>
		<driverClass>ApexMechanoids.JobDriver_HookPawn</driverClass>
		<reportString>retracting grappling hook towards TargetA.</reportString>
		<abilityCasting>true</abilityCasting>
		<playerInterruptible>false</playerInterruptible>
		<casualInterruptible>false</casualInterruptible>
	</JobDef>
