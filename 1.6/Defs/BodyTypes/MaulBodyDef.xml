<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Maul: Heavy suppressor/brawler mech. 3-directional textures. LeftHand, RightHand, HeadAttackTool.
       Bipedal heavy-build humanoid. High health scale (3.5). Large arms, heavy fists. 
       Inherits from Lancer. Broad shoulders, no delicate fingers — powerful fist-clamps. -->
  <BodyDef>
    <defName>APM_Maul</defName>
    <label>maul</label>
    <corePart>
      <def>MechanicalThorax</def>
      <height>Middle</height>
      <depth>Outside</depth>
      <parts>
        <li>
          <def>MechanicalNeck</def>
          <coverage>0.10</coverage>
          <height>Top</height>
          <parts>
            <li>
              <def>MechanicalHead</def>
              <coverage>0.80</coverage>
              <groups>
                <li>HeadAttackTool</li>
              </groups>
              <parts>
                <li>
                  <def>ArtificialBrain</def>
                  <coverage>0.10</coverage>
                  <depth>Inside</depth>
                </li>
                <li>
                  <def>SightSensor</def>
                  <customLabel>central sight sensor</customLabel>
                  <coverage>0.20</coverage>
                </li>
                <li>
                  <def>HearingSensor</def>
                  <customLabel>left hearing sensor</customLabel>
                  <coverage>0.10</coverage>
                </li>
                <li>
                  <def>HearingSensor</def>
                  <customLabel>right hearing sensor</customLabel>
                  <coverage>0.10</coverage>
                </li>
                <li>
                  <def>SmellSensor</def>
                  <coverage>0.08</coverage>
                </li>
              </parts>
            </li>
          </parts>
        </li>
        <li>
          <def>MechanicalShoulder</def>
          <customLabel>left mechanical shoulder</customLabel>
          <coverage>0.20</coverage>
          <parts>
            <li>
              <def>MechanicalArm</def>
              <customLabel>left arm</customLabel>
              <coverage>0.85</coverage>
              <parts>
                <li>
                  <def>MechanicalHand</def>
                  <customLabel>left fist</customLabel>
                  <coverage>0.3</coverage>
                  <height>Bottom</height>
                  <parts>
                    <li>
                      <def>MechanicalFinger</def>
                      <customLabel>left grip</customLabel>
                      <coverage>0.5</coverage>
                      <groups>
                        <li>LeftHand</li>
                      </groups>
                    </li>
                  </parts>
                </li>
              </parts>
            </li>
          </parts>
        </li>
        <li>
          <def>MechanicalShoulder</def>
          <customLabel>right mechanical shoulder</customLabel>
          <coverage>0.20</coverage>
          <parts>
            <li>
              <def>MechanicalArm</def>
              <customLabel>right arm</customLabel>
              <coverage>0.85</coverage>
              <parts>
                <li>
                  <def>MechanicalHand</def>
                  <customLabel>right fist</customLabel>
                  <coverage>0.3</coverage>
                  <height>Bottom</height>
                  <parts>
                    <li>
                      <def>MechanicalFinger</def>
                      <customLabel>right grip</customLabel>
                      <coverage>0.5</coverage>
                      <groups>
                        <li>RightHand</li>
                      </groups>
                    </li>
                  </parts>
                </li>
              </parts>
            </li>
          </parts>
        </li>
        <li>
          <def>MechanicalLeg</def>
          <customLabel>left leg</customLabel>
          <coverage>0.22</coverage>
          <height>Bottom</height>
          <parts>
            <li>
              <def>MechanicalFoot</def>
              <customLabel>left foot</customLabel>
              <coverage>0.2</coverage>
            </li>
          </parts>
        </li>
        <li>
          <def>MechanicalLeg</def>
          <customLabel>right leg</customLabel>
          <coverage>0.22</coverage>
          <height>Bottom</height>
          <parts>
            <li>
              <def>MechanicalFoot</def>
              <customLabel>right foot</customLabel>
              <coverage>0.2</coverage>
            </li>
          </parts>
        </li>
        <li>
          <def>Reactor</def>
          <coverage>0.06</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>FluidReprocessor</def>
          <coverage>0.04</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>FluidReprocessor</def>
          <coverage>0.04</coverage>
          <depth>Inside</depth>
        </li>
      </parts>
    </corePart>
  </BodyDef>

</Defs>
