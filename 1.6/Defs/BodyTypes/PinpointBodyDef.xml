<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Pinpoint: Lightweight spotter/designator mech. 4-directional textures. HeadAttackTool only.
       Uses Mech_Light body currently. Slender bipedal form — sensor head dominant, minimal limbs.
       No hands (no LeftHand/RightHand groups). Custom sensor-focused head, lean body, two legs. -->
  <BodyDef>
    <defName>APM_Pinpoint</defName>
    <label>pinpoint</label>
    <corePart>
      <def>APM_PinpointBody</def>
      <height>Middle</height>
      <depth>Outside</depth>
      <parts>
        <li>
          <def>MechanicalNeck</def>
          <coverage>0.08</coverage>
          <height>Top</height>
          <parts>
            <li>
              <def>APM_PinpointSensorHead</def>
              <customLabel>sensor head</customLabel>
              <coverage>0.80</coverage>
              <groups>
                <li>HeadAttackTool</li>
              </groups>
              <parts>
                <li>
                  <def>ArtificialBrain</def>
                  <coverage>0.10</coverage>
                  <depth>Inside</depth>
                </li>
                <li>
                  <def>SightSensor</def>
                  <customLabel>primary targeting sensor</customLabel>
                  <coverage>0.30</coverage>
                </li>
                <li>
                  <def>SightSensor</def>
                  <customLabel>secondary sensor</customLabel>
                  <coverage>0.15</coverage>
                </li>
                <li>
                  <def>HearingSensor</def>
                  <customLabel>left hearing sensor</customLabel>
                  <coverage>0.08</coverage>
                </li>
                <li>
                  <def>HearingSensor</def>
                  <customLabel>right hearing sensor</customLabel>
                  <coverage>0.08</coverage>
                </li>
              </parts>
            </li>
          </parts>
        </li>
        <li>
          <def>MechanicalLeg</def>
          <customLabel>left leg</customLabel>
          <coverage>0.20</coverage>
          <height>Bottom</height>
          <parts>
            <li>
              <def>MechanicalFoot</def>
              <customLabel>left foot</customLabel>
              <coverage>0.2</coverage>
            </li>
          </parts>
        </li>
        <li>
          <def>MechanicalLeg</def>
          <customLabel>right leg</customLabel>
          <coverage>0.20</coverage>
          <height>Bottom</height>
          <parts>
            <li>
              <def>MechanicalFoot</def>
              <customLabel>right foot</customLabel>
              <coverage>0.2</coverage>
            </li>
          </parts>
        </li>
        <li>
          <def>Reactor</def>
          <coverage>0.06</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>FluidReprocessor</def>
          <coverage>0.04</coverage>
          <depth>Inside</depth>
        </li>
      </parts>
    </corePart>
  </BodyDef>

  <BodyPartDef>
    <defName>APM_PinpointBody</defName>
    <label>body</label>
    <hitPoints>60</hitPoints>
    <permanentInjuryChanceFactor>0</permanentInjuryChanceFactor>
    <skinCovered>false</skinCovered>
    <solid>true</solid>
    <alive>false</alive>
    <bleedRate>0</bleedRate>
  </BodyPartDef>

  <BodyPartDef>
    <defName>APM_PinpointSensorHead</defName>
    <label>sensor head</label>
    <hitPoints>50</hitPoints>
    <frostbiteVulnerability>2</frostbiteVulnerability>
    <permanentInjuryChanceFactor>0</permanentInjuryChanceFactor>
    <skinCovered>false</skinCovered>
    <solid>true</solid>
    <alive>false</alive>
    <bleedRate>0</bleedRate>
    <tags>
      <li>SightSource</li>
    </tags>
  </BodyPartDef>

</Defs>
