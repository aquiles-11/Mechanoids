<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>APM_MechCommandCasket</defName>
		<label>mech command casket</label>
		<description>The mech command casket is a fusion of mechlink and cryptosleep casket technology, allowing the enclosed user to control their mechanoids from the relative safety of the casket. The signal boosting capabilities of this machine allow the mechanitor to control their mechs even when world tiles away from them.</description>
		<tickerType>Normal</tickerType>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/MechCommandCasket/MechCommandCasket</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,2)</drawSize>
			<drawOffset>(0,0,0)</drawOffset>
		</graphicData>
		<thingCategories>
			<li>BuildingsMisc</li>
		</thingCategories>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<minifiedDef>MinifiedThing</minifiedDef>
		<canOverlapZones>false</canOverlapZones>
		<pathCost>42</pathCost>
		<blockWind>true</blockWind>
		<fillPercent>0.5</fillPercent>
		<building>
			<paintable>false</paintable>
			<destroySound>BuildingDestroyed_Metal_Big</destroySound>
			<buildingTags>
				<li>Biotech</li>
			</buildingTags>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<designationCategory>Biotech</designationCategory>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>2200</WorkToBuild>
			<Mass>20</Mass>
			<Flammability>0.6</Flammability>
		</statBases>
		<size>(3,2)</size>
		<rotatable>true</rotatable>
		<defaultPlacingRot>South</defaultPlacingRot>
		<interactionCellOffset>(0,0,2)</interactionCellOffset>
		<hasInteractionCell>true</hasInteractionCell>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<costList>
			<Steel>120</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<constructionSkillPrerequisite>5</constructionSkillPrerequisite>
		<researchPrerequisites>
			<li>MicroelectronicsBasics</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>200</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable" />
			<li Class="CompProperties_Breakdownable" />
			<li Class="ApexMechanoids.CompProperties_RemoteControlUplink" />
			<li Class="ApexMechanoids.CompProperties_RemoteMechCasketAbilities">

			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
	</ThingDef>

</Defs>